# Server
PORT=3012
NODE_ENV=development

# Database
DATABASE_URL="postgresql://censo_user:censo_pass@localhost:5432/censo_emergencia?schema=public"

# Auth
JWT_SECRET=replace-with-32-bytes-random-string
JWT_REFRESH_SECRET=replace-with-different-32-bytes-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated list of allowed frontend origins)
# Local dev:
CORS_ORIGIN=http://localhost:3013
# Producción (sin Nginx - opción B):
# CORS_ORIGIN=http://correspondencia.cvm.com.ve:3013
# Producción (con Nginx - opción A, recomendado):
# CORS_ORIGIN=https://correspondencia.cvm.com.ve

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PUBLIC=10
RATE_LIMIT_MAX_LOGIN=5
